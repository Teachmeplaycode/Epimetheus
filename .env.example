# LLM API Keys
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_BASE_URL=

# Crawler settings
CRAWL_DELAY_MIN=1.5
CRAWL_DELAY_MAX=3.0
CRAWL_MAX_PER_DAY=100000
CRAWL_USER_AGENT=Epimetheus/0.1 (research project; incremental crawl; contact@example.com)

# Data storage
DATA_DIR=./data

# Docker
CRAWL_SOURCE=v2ex
CRAWL_MAX_PER_RUN=500
CRAWL_LOOP_INTERVAL=3600

# Reddit API (for reddit crawler)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Proxy (if needed, e.g. for V2EX from mainland China)
HTTPS_PROXY=
